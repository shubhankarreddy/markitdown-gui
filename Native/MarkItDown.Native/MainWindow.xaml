<Window x:Class="MarkItDown.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MarkItDown"
        Icon="Assets/MarkItDown.ico"
        Width="1220"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        FontFamily="Segoe UI"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop">
  <DockPanel LastChildFill="True">
    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <TextBlock x:Name="StatusTextBlock" Text="Ready." />
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Padding="16,16,10,16"
              Background="#FAFBFC"
              BorderBrush="#D0D7DE"
              BorderThickness="1"
              CornerRadius="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly">
          <StackPanel Margin="0,0,6,0">
            <TextBlock Text="MarkItDown"
                       FontSize="26"
                       FontWeight="SemiBold" />

            <TextBlock Text="Native Windows document-to-Markdown converter. Drag files here or use the controls below."
                       Margin="0,6,0,16"
                       Foreground="#5F6B7A"
                       TextWrapping="Wrap" />

            <Button x:Name="AddFilesButton"
                    Height="34"
                    Content="Add Files..."
                    Click="AddFilesButton_Click" />

            <TextBlock Text="Website URL"
                       Margin="0,12,0,4"
                       FontWeight="SemiBold" />

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBox x:Name="UrlTextBox"
                       Grid.Column="0"
                       Height="34"
                       VerticalContentAlignment="Center"
                       ToolTip="https://example.com"
                       KeyDown="UrlTextBox_KeyDown" />

              <Button x:Name="AddUrlButton"
                      Grid.Column="2"
                      MinWidth="90"
                      Height="34"
                      Content="Add URL"
                      Click="AddUrlButton_Click" />
            </Grid>

            <GroupBox Header="Output Folder"
                      Margin="0,16,0,0">
              <StackPanel>
                <Button x:Name="SelectOutputButton"
                        Height="32"
                        Content="Choose Folder..."
                        Click="SelectOutputButton_Click" />

                <TextBlock x:Name="OutputFolderTextBlock"
                           Margin="0,8,0,0"
                           Foreground="#5F6B7A"
                           Text="No output folder selected. Conversion still works, but files will not be auto-saved."
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Queue"
                      Margin="0,14,0,0">
              <StackPanel>
                <ListView x:Name="QueueListView"
                          Height="168"
                          SelectionChanged="QueueListView_SelectionChanged">
                  <ListView.View>
                    <GridView>
                      <GridViewColumn Header="Status"
                                      Width="80"
                                      DisplayMemberBinding="{Binding StatusLabel}" />
                      <GridViewColumn Header="Name"
                                      Width="200"
                                      DisplayMemberBinding="{Binding DisplayName}" />
                    </GridView>
                  </ListView.View>
                </ListView>

                <Grid Margin="0,8,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <Button x:Name="RemoveSelectedButton"
                          Grid.Column="0"
                          Height="30"
                          Content="Remove Selected"
                          Click="RemoveSelectedButton_Click" />

                  <Button x:Name="ClearButton"
                          Grid.Column="2"
                          Height="30"
                          Content="Clear Queue"
                          Click="ClearButton_Click" />
                </Grid>
              </StackPanel>
            </GroupBox>

            <CheckBox x:Name="EnableLlmCheckBox"
                      Margin="0,14,0,0"
                      Content="Enable LLM descriptions"
                      Checked="EnableLlmCheckBox_Changed"
                      Unchecked="EnableLlmCheckBox_Changed" />

            <GroupBox x:Name="LlmGroupBox"
                      Header="LLM Settings"
                      Margin="0,8,0,0"
                      Visibility="Collapsed">
              <StackPanel>
                <TextBlock Text="OpenAI API key" />
                <PasswordBox x:Name="ApiKeyPasswordBox"
                             Margin="0,4,0,10" />

                <TextBlock Text="Model" />
                <ComboBox x:Name="ModelComboBox"
                          Margin="0,4,0,0"
                          SelectedIndex="1">
                  <ComboBoxItem Content="gpt-4o" />
                  <ComboBoxItem Content="gpt-4o-mini" />
                  <ComboBoxItem Content="gpt-4.1" />
                </ComboBox>
              </StackPanel>
            </GroupBox>

            <Button x:Name="ConvertAllButton"
                    Margin="0,16,0,0"
                    Height="40"
                    FontWeight="SemiBold"
                    Content="Convert All"
                    Click="ConvertAllButton_Click" />

            <ProgressBar x:Name="ConversionProgressBar"
                         Margin="0,10,0,0"
                         Height="12"
                         Visibility="Collapsed" />
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="#FFFFFF"
                BorderBrush="#D0D7DE"
                BorderThickness="1"
                CornerRadius="10">
          <StackPanel>
            <TextBlock x:Name="SelectedItemTextBlock"
                       Text="No item selected"
                       FontSize="22"
                       FontWeight="SemiBold" />

            <TextBlock x:Name="StatsTextBlock"
                       Margin="0,6,0,0"
                       Foreground="#5F6B7A"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="0,12,0,0">
          <TabItem Header="Markdown">
            <TextBox x:Name="MarkdownTextBox"
                     AcceptsReturn="True"
                     HorizontalScrollBarVisibility="Auto"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Cascadia Mono, Consolas, Courier New" />
          </TabItem>

          <TabItem Header="Details">
            <TextBox x:Name="DetailsTextBox"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
          </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
          <Button x:Name="CopyButton"
                  Width="100"
                  Margin="0,0,8,0"
                  Content="Copy"
                  Click="CopyButton_Click"
                  IsEnabled="False" />

          <Button x:Name="SaveButton"
                  Width="120"
                  Margin="0,0,8,0"
                  Content="Save As..."
                  Click="SaveButton_Click"
                  IsEnabled="False" />

          <Button x:Name="OpenFolderButton"
                  Width="150"
                  Content="Open Output Folder"
                  Click="OpenFolderButton_Click"
                  IsEnabled="False" />
        </StackPanel>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
